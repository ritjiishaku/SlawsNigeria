// src/db/schema.prisma

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  entrepreneur
  parent
  teen
  volunteer
}

enum Gender {
  female
  male
  prefer_not_to_say
}

enum AgeGroup {
  teen
  twenty_thirty
  thirty_fortyfive
  fortysix_sixty
  sixtyone_seventy
  seventy_plus
}

enum OnboardingStage {
  not_started
  in_progress
  complete
}

enum SubscriptionPlan {
  free
  basic
  premium
}

enum SubscriptionStatus {
  active
  expired
  cancelled
  pending
}

enum BillingCycle {
  monthly
  quarterly
  annually
}

enum ProductCategory {
  women_store
  event_service
  mentorship
  course
  consulting
}

enum Availability {
  in_stock
  out_of_stock
  coming_soon
}

enum AccessLevel {
  public
  subscriber_only
}

enum EventType {
  standard
  VIP
  professional
  private
}

enum EventStatus {
  upcoming
  ongoing
  completed
  cancelled
}

enum VolunteerRole {
  customer_service
  inventory
  executive
  social_media
  other
}

enum VolunteerStatus {
  applied
  under_review
  active
  inactive
  rejected
}

model User {
  id               String          @id @default(uuid())
  full_name        String
  phone            String          // +234XXXXXXXXXX format
  email            String?
  state            String          // Nigerian state
  gender           Gender
  age_group        AgeGroup
  role             Role
  subscription_id  String?         @unique
  subscription     Subscription?   @relation(fields: [subscription_id], references: [id])
  onboarding_stage OnboardingStage @default(not_started)
  joined_at        DateTime        @default(now())
  last_active      DateTime        @updatedAt
  consent_given    Boolean         @default(false) // NDPA 2023 compliance
  volunteer        Volunteer?
  interaction_logs InteractionLog[]
}

model Subscription {
  id            String             @id @default(uuid())
  user_id       String             @unique
  user          User?
  plan          SubscriptionPlan
  status        SubscriptionStatus
  amount_paid   Decimal            // in Nigerian Naira (₦)
  billing_cycle BillingCycle
  start_date    DateTime
  end_date      DateTime
  auto_renew    Boolean            @default(true)
  payment_ref   String             // Paystack or Flutterwave transaction reference
  created_at    DateTime           @default(now())
}

model Product {
  id           String          @id @default(uuid())
  name         String
  category     ProductCategory
  description  String          // subscriber-gated
  price        Decimal         // in Nigerian Naira (₦)
  currency     String          @default("NGN")
  availability Availability
  access_level AccessLevel
  media_urls   String?
  tags         String?
  created_at   DateTime        @default(now())
  updated_at   DateTime        @updatedAt
}

model Event {
  id           String      @id @default(uuid())
  title        String
  type         EventType
  description  String      // subscriber-gated
  date         DateTime
  time         String      // HH:mm format
  location     String      // Nigerian city and venue name
  state        String      // Nigerian state
  capacity     Int?        // null = unlimited
  price        Decimal     // in ₦; 0 if free
  access_level AccessLevel
  status       EventStatus
  booking_link String?
  created_at   DateTime    @default(now())
}

model Volunteer {
  id               String          @id @default(uuid())
  user_id          String          @unique
  user             User            @relation(fields: [user_id], references: [id])
  role             VolunteerRole
  skills           String?
  availability     String          // full_time | part_time | weekends_only
  status           VolunteerStatus @default(applied)
  agreement_signed Boolean         @default(false)
  onboarded_at     DateTime?
  created_at       DateTime        @default(now())
}

model InteractionLog {
  id            String   @id @default(uuid())
  user_id       String?
  user          User?    @relation(fields: [user_id], references: [id])
  session_id    String
  intent        String   // detected intent (e.g. discovery, purchase_intent)
  message       String
  response      String
  resolved      Boolean  @default(true)
  escalated_to  String?  // WhatsApp number if escalated
  response_ms   Int
  created_at    DateTime @default(now())
}
